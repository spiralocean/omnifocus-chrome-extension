{
  "manifest_version": 3,
  "name": "Clip to OmniFocus",
  "version": "1.0.0",
  "description": "Clip articles and web pages into OmniFocus tasks with one click.",
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "16.4"
    }
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "nativeMessaging",
    "notifications",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Clip to OmniFocus",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "commands": {
    "clip-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Clip current page to OmniFocus"
    },
    "clip-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Clip selected text to OmniFocus"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}